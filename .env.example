# Copy this file to ".env" and fill in your own values.
# The real ".env" is git-ignored and must NEVER be committed.

# RPC endpoint for Base Sepolia testnet.
# Default public endpoint works; you can also use Alchemy/Infura/QuickNode.
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Private key of the wallet used to deploy (testnet wallet only!).
# Export from your wallet. Use a throwaway/testnet account, never your main one.
# Format: 0x followed by 64 hex characters.
PRIVATE_KEY=
